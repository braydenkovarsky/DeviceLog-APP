<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/secondaryProgress">
        <shape android:innerRadiusRatio="3" android:shape="ring" android:thickness="10dp" android:useLevel="false">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape android:innerRadiusRatio="3" android:shape="ring" android:thickness="10dp" android:useLevel="true">
                <gradient android:startColor="#4DD8FF" android:centerColor="#00BCD4" android:endColor="#4DD8FF" android:type="sweep" />
            </shape>
        </rotate>
    </item>
</layer-list>