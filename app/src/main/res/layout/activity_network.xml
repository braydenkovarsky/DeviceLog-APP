<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F111A">

    <LinearLayout
        android:id="@+id/mainDashboardContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="32dp"
            android:paddingBottom="8dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#64FFDA"
                android:padding="1dp">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/topAppBar"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="#0F111A"
                    app:navigationIcon="@drawable/ic_menu"
                    app:navigationIconTint="@android:color/white"
                    app:title="InfoCore"
                    app:titleTextColor="@android:color/white"
                    app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="Network Ping Tester"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/glass_card_selected"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvConnectionType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connection: --"
                        android:textColor="#64FFDA"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSignal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Signal: --"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/glass_card_simple"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Select Server:"
                        android:textAllCaps="true"
                        android:textColor="#B0BEC5"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/spinnerServers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@android:color/white" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRunPing"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:text="Run Ping Test"
                    android:textColor="#4DD8FF"
                    app:cornerRadius="28dp"
                    app:strokeColor="#4DD8FF"
                    app:strokeWidth="1dp" />

                <ProgressBar
                    android:id="@+id/progressPing"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginBottom="16dp"
                    android:indeterminate="true"
                    android:progressTint="#64FFDA"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/glass_card_selected"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvPingResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Result: -- ms"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/glass_card_simple"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <EditText
                        android:id="@+id/etCustomServer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="IP or DNS Address"
                        android:textColor="@android:color/white"
                        android:textColorHint="#4DFFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPingCustom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ping"
                        android:textColor="#0F111A"
                        app:backgroundTint="#64FFDA"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/glass_card_simple"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Ping History"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tvPingHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No history logs yet."
                        android:textColor="#B0BEC5"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="32dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveHistory"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Save"
                        android:textColor="#4DD8FF"
                        app:cornerRadius="28dp"
                        app:strokeColor="#4DD8FF"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearHistory"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Clear"
                        android:textColor="#4DD8FF"
                        app:cornerRadius="28dp"
                        app:strokeColor="#4DD8FF"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginTop="75dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/hud_blade_bg"
        app:insetForeground="@android:color/transparent"
        app:elevation="12dp"
        app:headerLayout="@null"
        app:itemVerticalPadding="12dp"
        app:itemIconPadding="16dp"
        app:itemIconTint="#64FFDA"
        app:itemTextColor="#FFFFFF"
        app:itemShapeFillColor="#1564FFDA"
        app:itemShapeInsetStart="8dp"
        app:itemShapeInsetEnd="8dp"
        app:itemShapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>