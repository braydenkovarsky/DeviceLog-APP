<resources>
    <style name="Theme.InfoCore.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F111A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.InfoCore</item>
    </style>

    <style name="Theme.InfoCore" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#0F111A</item>
        <item name="android:navigationBarColor">#0F111A</item>

        <item name="colorPrimary">#64FFDA</item>
        <item name="colorOnPrimary">#0F111A</item>
        <item name="colorSurface">#0F111A</item>
        <item name="colorOnSurface">#FFFFFF</item>

        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>