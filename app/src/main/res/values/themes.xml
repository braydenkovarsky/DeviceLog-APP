<resources>
    <style name="Theme.InfoCore.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F111A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.InfoCore</item>
    </style>

    <style name="Theme.InfoCore" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#0F111A</item>
        <item name="android:navigationBarColor">#0F111A</item>

        <item name="colorPrimary">#64FFDA</item>
        <item name="colorOnPrimary">#0F111A</item>
        <item name="colorSurface">#1A1C26</item> <item name="colorOnSurface">#FFFFFF</item>

        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="ShapeAppearance.InfoCore.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="NavMenuItemStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
</resources>